# Path to the folder that contains your downloaded messages (the colmsg root).
# Each sub-folder is a group, each sub-sub-folder is a member.
MEDIA_DIR=/path/to/your/colmsg

# Port the Express server listens on (default: 3001)
PORT=3001

# Comma-separated list of member names (in Japanese) to show as "Online"
# Leave empty to show ALL members as Online.
ONLINE_MEMBERS=一ノ瀬美空,井上和,奥田いろは,田村真佑

#Input your name
YOUR_NAME=あなた

# Comma-separated Tailscale/custom hostnames allowed by the Vite dev server
# Leave empty to allow no external hosts.
ALLOWED_HOSTS=yourhostname.ts.net
