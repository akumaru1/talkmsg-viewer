{
  "name": "mobame",
  "version": "1.0.0",
  "description": "Nogizaka46 Mobame viewer – monorepo root",
  "private": true,
  "scripts": {
    "setup": "npm install && npm install --prefix server && npm install --prefix client",
    "server": "node server/index.js",
    "client": "npm run --prefix client dev",
    "dev": "concurrently --kill-others-on-fail --names \"server,client\" --prefix-colors \"blue,cyan\" \"npm run server\" \"npm run client\"",
    "generate": "node generate_data.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "music-metadata": "^7.14.0"
  }
}
